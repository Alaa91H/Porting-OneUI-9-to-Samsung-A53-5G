# Use LF line endings for all shell scripts and Python (required for Linux CI)
*.sh text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.conf text eol=lf
*.list text eol=lf
*.patch text eol=lf
*.xml text eol=lf
*.env text eol=lf
LICENSE text eol=lf

# Binary artefacts (never diff)
*.img binary
*.tar binary
*.tar.md5 binary
*.tar.xz binary
*.zip binary
*.lz4 binary
*.zst binary
*.apk binary
