# ============================================================
# إعدادات جهاز المصدر — Samsung Galaxy S26 Ultra (One UI 9)
# عدّل القيم حسب الطراز الفعلي للفيرموير التي تحملها.
# ============================================================

# --- معرّفات الجهاز ---
DEVICE_CODENAME=s26x
DEVICE_MODEL=SM-S948B
DEVICE_MODEL_REGION=XEU
DEVICE_ARCH=arm64-v8a
DEVICE_MANUFACTURER=samsung

# --- إصدارات البرمجيات ---
ANDROID_VERSION=16
ANDROID_SDK=36
ONEUI_VERSION=9.0
SECURITY_PATCH=2026-07-01
BUILD_ID=UP1A.231005.007

# --- بنية الأقسام ---
VAB_DEVICE=true                       # Virtual A/B
DYNAMIC_PARTITIONS=true
SUPER_PARTITION_SIZE=11811160064      # ~11 GiB — تحقق من cmdline الجهاز الفعلي
GROUP_NAME=qti_dynamic_partitions
EROFs_SUPPORTED=true                  # صور النظام من نوع EROFS

# --- رابط الفيرموير (اتركه فارغاً واستخدم GitHub Secret SOURCE_FIRMWARE_URL) ---
FIRMWARE_URL=
FIRMWARE_FILE=                        # اسم الملف المتوقع بدون المسار
FIRMWARE_KEY=

# --- مسار التطبيقات/الإطارات المراد نسخها للبورت ---
# هذه المسارات داخل الصورة المُستخرجة (نسبية لجذر القسم)
PORT_PATHS_SYSTEM="framework app priv-app etc/etc overlay"
PORT_PATHS_PRODUCT="app priv-app etc overlay"
PORT_PATHS_SYSTEM_EXT="app priv-app framework"

# --- بصمة الجهاز (تُنسخ لتجاوز فحوصات One UI عند الحاجة) ---
FINGERPRINT=samsung/s26xxx/s26x:16/UP1A.231005.007/S948BXXUxxxx:user/release-keys
