# ============================================================
# إعدادات جهاز الهدف — Samsung Galaxy A53 5G
# نُحافظ على vendor/boot/odm من هذا الجهاز ونُطبّق One UI 9 فوقها.
# ============================================================

# --- معرّفات الجهاز ---
DEVICE_CODENAME=a53x
DEVICE_MODEL=SM-A536B
DEVICE_MODEL_REGION=EUX
DEVICE_ARCH=arm64-v8a
DEVICE_MANUFACTURER=samsung

# --- إصدارات البرمجيات ---
# بعد البورت نرفع android.version إلى 16، لكن vendor يبقى على إصداره الأصلي.
ANDROID_VERSION=16
ANDROID_SDK=36
ONEUI_VERSION=9.0
SECURITY_PATCH=2026-07-01
BUILD_ID=UP1A.231005.007
VENDOR_ANDROID=14                    # إصدار vendor الهدف الأصلي (لا يُغيَّر)
VENDOR_SECURITY_PATCH=2024-10-01

# --- بنية الأقسام ---
VAB_DEVICE=true
DYNAMIC_PARTITIONS=true
SUPER_PARTITION_SIZE=9126805504      # ~8.5 GiB — تحقق: adb shell sm partition disk:super
GROUP_NAME=dynamic_partitions_a
EROFs_SUPPORTED=true

# --- الأقسام التي تُؤخذ من الهدف مباشرة (لا تُبورت) ---
KEEP_FROM_TARGET="vendor vendor_boot init_boot dtbo modem"

# --- الأقسام التي تُبورت من المصدر ---
PORT_FROM_SOURCE="system product system_ext"

# --- رابط الفيرموير (استخدم GitHub Secret TARGET_FIRMWARE_URL) ---
FIRMWARE_URL=
FIRMWARE_FILE=
FIRMWARE_KEY=

# --- بصمة الجهاز الهدف (تُضبط في build.prop بعد البورت) ---
FINGERPRINT=samsung/a53xxx/a53x:16/UP1A.231005.007/A536BXXUxxxx:user/release-keys
RO_BUILD_PRODUCT=a53x
RO_BUILD_DEVICE=a53x

# --- إعدادات الأمان ---
DISABLE_DM_VERITY=true               # تعطيل dm-verity على super المعدّل
DISABLE_FORCEENCRYPT=true            # السماح بـ /data غير مشفّر لتسهيل التشخيص
PATCH_BOOT_FORCEENCRYPT=true
