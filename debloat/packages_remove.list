# ============================================================
# packages_remove.list — حزم التضخيم المرشّحة للحذف
# الصيغة: <package_name> [level] # تعليق
# المستويات: lite, standard, aggressive
# السطور التي تبدأ بـ # تعليقات وتُتجاهل.
# ============================================================

# ---------- مستوى lite: تطبيقات تسويقية وإقليمية ----------
# شبكات اجتماعية مثبّتة مسبقاً (bloatware مدفوع من شركات)
com.facebook.katana                  lite    # Facebook
com.facebook.system                  lite    # Facebook system app
com.facebook.appmanager              lite    # Facebook manager
com.facebook.services                lite    # Facebook services
com.instagram.android                lite    # Instagram
com.snapchat.android                 lite    # Snapchat
com.netflix.mediaclient              lite    # Netflix
com.spotify.music                    lite    # Spotify
com.microsoft.office.excel           lite    # MS Excel
com.microsoft.office.word            lite    # MS Word
com.microsoft.office.powerpoint      lite    # MS PowerPoint
com.microsoft.skydrive               lite    # OneDrive
com.linkedin.android                 lite    # LinkedIn
com.booking                          lite    # Booking.com
com.ebay.mobile                      lite    # eBay
com.amazon.mShop.android.shopping    lite    # Amazon Shopping
com.tencent.mm                       lite    # WeChat (إقليمي)
com.vkontakte.android                lite    # VK
com.zhiliaoapp.musically             lite    # TikTok
ss.android.ugc.aweme                 lite    # TikTok (alt)
com.shopee.id                        lite    # Shopee

